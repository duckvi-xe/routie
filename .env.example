# =============================================================================
#  Routie — Environment variables for docker-compose
# =============================================================================
# Copy this file to .env and customize:
#   cp .env.example .env

# --- Backend ---
USE_DB=true
DATABASE_URL=sqlite+aiosqlite:///data/routie.db
LOG_LEVEL=info
CORS_ORIGINS=*

# --- PostgreSQL (--profile prod) ---
POSTGRES_PASSWORD=routie

# --- ngrok Tunnel (--profile tunnel) ---
# Sign up at https://ngrok.com and get your token
NGROK_AUTHTOKEN=
# Optional: custom domain (requires paid ngrok plan)
NGROK_DOMAIN=
