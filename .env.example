# =============================================================================
#  Routie — Environment Variables
#  Copy this file to .env and edit for your local setup
# =============================================================================

# ── Backend ───────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info
CORS_ORIGINS=*

# ── Database ──────────────────────────────────────────────────────────────────
USE_DB=false
DATABASE_URL=sqlite+aiosqlite:///data/routie.db

# ── Route Provider ────────────────────────────────────────────────────────────
# "mock" = algorithmic route generation (no external deps)
# "graphhopper" = real road routing via GraphHopper microservice
ROUTE_PROVIDER=mock

# GraphHopper service URL (Docker compose internal DNS)
GRAPHOPPER_URL=http://graphhopper:8989

# Optional API key for hosted GraphHopper (GraphHopper Cloud)
GRAPHOPPER_API_KEY=

# ── PostgreSQL (prod profile) ─────────────────────────────────────────────────
POSTGRES_PASSWORD=routie

# ── ngrok Tunnel (tunnel profile) ────────────────────────────────────────────
NGROK_AUTHTOKEN=
NGROK_DOMAIN=
